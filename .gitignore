# =============================================================================
# Samarth Portfolio — .gitignore
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────────────────────
/.next/
/out/
/build

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage
/.nyc_output

# ── Environment variables ─────────────────────────────────────────────────────
# Never commit secrets. Use Vercel env dashboard for production values.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Vercel deployment ─────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ── Editor-specific ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
.cache/
